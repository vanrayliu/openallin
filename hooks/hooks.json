{
  "hooks": [
    {
      "event": "SessionStart",
      "script": "hooks/session-start.js",
      "description": "会话启动时加载项目上下文、状态和记忆"
    },
    {
      "event": "SessionEnd",
      "script": "hooks/session-end.js",
      "description": "会话结束时持久化状态和提取学习模式"
    },
    {
      "event": "PreToolUse",
      "script": "hooks/pre-tool-use.js",
      "description": "工具执行前安全检查"
    },
    {
      "event": "PostToolUse",
      "script": "hooks/post-tool-use.js",
      "description": "工具执行后审计"
    }
  ]
}
